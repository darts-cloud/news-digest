# コピーして使う: cp .env.example .env
# .env は .gitignore 対象（コミットしない）

# Discord Incoming Webhook（必須: discord_post / news_digest 投稿時）
DISCORD_WEBHOOK_URL=

# Google AI Studio の API キー（必須: gemini-cli / run_gemini_digest 実行時）
GEMINI_API_KEY=

# 任意: GOOGLE_API_KEY でも可（Gemini CLI が読む場合あり）
# GOOGLE_API_KEY=

# 任意: ダイジェストのトピック（空なら主要ニュース全般）
NEWS_DIGEST_TOPIC=

# 任意: モデル（未設定時はスクリプト既定）
GEMINI_MODEL=gemini-2.5-flash
